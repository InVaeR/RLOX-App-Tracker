{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "RLOX App Tracker Update Manifest",
    "type": "object",
    "required": ["schemaVersion", "product", "version", "installer"],
    "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "product": { "type": "string", "pattern": "^rlox-app-tracker$" },
        "channel": { "type": "string", "enum": ["stable", "beta", "dev"] },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-\\w+(\\.\\d+)?)?$" },
        "minimumLauncherVersion": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "mandatory": { "type": "boolean" },
        "installer": {
            "type": "object",
            "required": ["url", "sha256", "size"],
            "properties": {
                "url": { "type": "string", "format": "uri" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "size": { "type": "integer", "minimum": 1 }
            }
        },
        "releaseNotesUrl": { "type": "string", "format": "uri" }
    }
}
